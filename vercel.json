{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "excludeFiles": "{dataset/**,data/**,logs/**,reports/**,database/**,runtime/**,.venv/**,__pycache__/**,**/*.pyc,models/20260428_2028_last_checkpoint.pth,train.py,evaluate.py,utils/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
